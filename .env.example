# Sticker Galaxy Arcade — local dev environment
# Copy to .env and fill in the values.
#
# Getting a dev session token:
#   DM @hollowtradr on Telegram. He'll generate one for you.
#   Tokens expire after 60 minutes.
#
# Without a token, add ?dev=1 to the URL (http://localhost:5173/?dev=1).
# The game boots in demo mode — full visual experience, no real midi rewards.

# Dev session token (from @hollowtradr on Telegram)
VITE_ARCADE_SESSION_TOKEN=

# Arcade API base URL (leave blank to use production)
VITE_ARCADE_API_URL=https://babyyoda-bot.vercel.app

# Your game ID (used in X-Game-Id header — matches your manifest)
VITE_GAME_ID=my_game_dev
